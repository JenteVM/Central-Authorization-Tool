API_LOCATION=location # (example: 0.0.0.0)
API_PORT=port_number # (example: 5000)
ALLOWED_REGISTRY_CREATORS=location,location,etc. # (example: https://google.com,https://safari.com)
DB_REGISTRY=registry_database_name # (example: Registry.db)

USERNAME=username # (example: JVM)
EMAIL=email # (example: JVM@location.place)
PASSWORD=password # (example: Password123)

DEFAULT_USER_AUTH_LEVEL=default_user_auth_level # (example: 1) This is the default auth level assigned to newly created users if no specific auth level is provided during user creation. It can be overridden by providing a specific auth level when creating a user.
DEFAULT_AUTH_LEVEL=default_auth_level # (example: 5) This is used for the administrative user
DEFAULT_AUTH_SCHEME=default_auth_scheme_as_string # (example: '{"notation": "integer", "else": {"allow_key": {"else": {"smaller_than": null, "bigger_than": "5", "allow": null, "ban": null}}, "hierarchy": {"main": "advanced", "advanced": {"else": {"else": {"smaller_than": null, "bigger_than": "self+1", "allow": null, "ban": null}}}, "except": null}, "except": null}, "except": ["5"]}')

TESTING=False #changing this to True will disable authentication for testing purposes (like when having switched user/registry models)